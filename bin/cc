#!/usr/bin/env zsh
# Launch Claude Code inside the nono AI profile.

set -e

for arg in "$@"; do
  case "$arg" in
    -c|-E|-S|-o|--version|-v|-###|\
    -arch|-isysroot|-shared|-dynamiclib|-static|-bundle|\
    -mmacosx-version-min=*|-miphoneos-version-min=*|-mios-simulator-version-min=*|\
    -Wl,*|-l*|-L*|-I*|-D*|-U*|-std=*|-O*|-g|\
    *.c|*.C|*.cc|*.cpp|*.cxx|*.m|*.mm|*.s|*.S|*.o|*.a|*.dylib|*.so|*.rlib)
      exec /usr/bin/cc "$@"
      ;;
  esac
done

mkdir -p "$HOME/.local/state"
[[ -e "$HOME/.local/state/agents.json" ]] || : >| "$HOME/.local/state/agents.json"
[[ -e "$HOME/.local/state/agents.json.lock" ]] || : >| "$HOME/.local/state/agents.json.lock"
exec env NONO_AUTO_MIGRATE=1 nono run \
  --profile ai \
  --allow-cwd \
  --allow-file "$HOME/.local/state/agents.json" \
  --allow-file "$HOME/.local/state/agents.json.lock" \
  --workdir "$PWD" -- \
    /usr/bin/env CLAUDE_CONFIG_DIR="$HOME/.config/claude" \
    claude --dangerously-skip-permissions "$@"
