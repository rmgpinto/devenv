#!/usr/bin/env zsh
# Open the current repository worktree in its Zellij code session.

set -e

source /Users/rmgpinto/dev/personal/devenv/lib/zellij/session.sh

prompt="${1:-}"
session=$(zellij_session_name_at "$PWD")

# Commands rendered by zjstatus have no TTY of their own. Capture the full
# client width before starting or switching sessions so they never call back
# into a Zellij server that is waiting for their output. Environment variables
# are not propagated reliably by `switch-session`, so persist it per session.
width="${COLUMNS:-$(tput cols 2>/dev/null || printf 110)}"
if [ -n "${ZELLIJ:-}" ]; then
  measured_width="$(zellij action list-panes --json 2>/dev/null \
    | jq -r '[.[].pane_columns // 0] | max // 0' 2>/dev/null || true)"
  if [[ "$measured_width" == <-> ]] && (( measured_width > width )); then
    width="$measured_width"
  fi
fi
export ZJSTATUS_AGENTS_WIDTH="$width"
width_session="${session//[^A-Za-z0-9_.-]/_}"
printf '%s\n' "$width" > "${TMPDIR:-/tmp}/zjstatus-agents-width-${width_session}"

# A prompt requires a fresh session so its generated layout is applied.
# Retain file detection temporarily for wt-spawn compatibility.
if { [ -n "$prompt" ] || [ -s "$PWD/.wt-claude-prompt" ]; } \
    && [ "${ZELLIJ_SESSION_NAME:-}" != "$session" ]; then
  zellij delete-session --force "$session" 2>/dev/null || true
  /Users/rmgpinto/dev/personal/devenv/bin/agent-state-hook prune 2>/dev/null || true
fi

if [ -n "$prompt" ]; then
  layout_file="/Users/rmgpinto/dev/personal/devenv/dotfiles/zellij/.config/zellij/layouts/code.kdl"
  encoded=$(printf '%s' "$prompt" | base64 | tr -d '\n')
  layout=$(<"$layout_file")
  layout=${layout/p=\\\"\\\"/p=\$(printf %s $encoded | base64 -d)}
  if [[ "$layout" == *'p=\"\"'* ]]; then
    echo "zcode: failed to inject the agent prompt into code.kdl" >&2
    exit 1
  fi
fi

if [ -n "${ZELLIJ:-}" ]; then
  if [ -n "$prompt" ]; then
    exec zellij action switch-session --layout-string "$layout" --cwd "$PWD" "$session"
  else
    exec zellij action switch-session --layout code --cwd "$PWD" "$session"
  fi
else
  if [ -n "$prompt" ]; then
    exec zellij --layout-string "$layout" attach --create "$session"
  else
    exec zellij --layout code attach --create "$session"
  fi
fi
