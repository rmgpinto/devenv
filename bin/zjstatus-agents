#!/usr/bin/env zsh

set -euo pipefail
unsetopt BG_NICE

export PATH="$HOME/.local/share/mise/installs/jq/latest:$PATH"

state_file="${AGENT_STATE_FILE:-$HOME/.local/state/agents.json}"
jq_bin="${JQ:-$(command -v jq 2>/dev/null || true)}"
osascript_bin="${OSASCRIPT:-/usr/bin/osascript}"

[[ -s "$state_file" && -n "$jq_bin" ]] || exit 0

rows="$($jq_bin -r \
  '
    def rank:
      if . == "waiting" then 0
      elif . == "working" or . == "tool" then 1
      elif . == "idle" then 2
      else 3
      end;

    to_entries
    | map({
        session: .key,
        status: (
          [.value.agents[]?
            | .status // "unknown"
          ]
          | sort_by(rank)
          | first // "unknown"
        )
      })
    | sort_by(.session | ascii_downcase)
    | .[]
    | [.session, .status] | @tsv
  ' "$state_file" 2>/dev/null || true)"
[[ -n "$rows" ]] || exit 0

# Ghostty tab titles begin with the Zellij session name (for example,
# "devenv-main | codex"). Render one equal-width cell per Ghostty tab so each
# active-agent label sits beneath the corresponding native tab.
typeset -A statuses
sessions=()
while IFS=$'\t' read -r session agent_status; do
  [[ -n "$session" ]] || continue
  statuses[$session]="$agent_status"
  sessions+=("$session")
done <<<"$rows"

tab_sessions=()
tab_center_ratios=()
tabs_cache="${TMPDIR:-/tmp}/zjstatus-ghostty-tabs.tsv"
tabs_lock="${tabs_cache}.lock"
cache_max_age="${ZJSTATUS_GHOSTTY_CACHE_AGE:-3}"
[[ "$cache_max_age" == <-> ]] || cache_max_age=3
now="$(date +%s)"
cached_at="$(stat -f %m "$tabs_cache" 2>/dev/null || printf '0')"

# All zjstatus instances share this snapshot. Only the process that acquires
# the lock calls macOS, and it combines titles and geometry in one AppleScript.
if (( now - cached_at >= cache_max_age )) && [[ -x "$osascript_bin" ]]; then
  lock_at="$(stat -f %m "$tabs_lock" 2>/dev/null || printf '0')"
  (( now - lock_at > 10 )) && rmdir "$tabs_lock" 2>/dev/null || true
  if mkdir "$tabs_lock" 2>/dev/null; then
    snapshot_tmp="${tabs_cache}.tmp.$$"
    trap 'rm -f "$snapshot_tmp"; rmdir "$tabs_lock" 2>/dev/null || true' EXIT
    "$osascript_bin" > "$snapshot_tmp" 2>/dev/null <<'APPLESCRIPT' || true
set tabNames to {}
tell application "Ghostty"
  if (count of windows) > 0 then
    repeat with ghosttyTab in tabs of front window
      set end of tabNames to name of ghosttyTab
    end repeat
  end if
end tell

tell application "System Events"
  tell process "Ghostty"
    set output to ""
    if (count of windows) > 0 then
      set ghosttyWindow to front window
      set tabGroups to every UI element of ghosttyWindow whose role is "AXTabGroup"
      if (count of tabGroups) > 0 then
        set tabGroup to item 1 of tabGroups
        set windowPosition to position of ghosttyWindow
        set windowSize to size of ghosttyWindow
        set windowX to item 1 of windowPosition
        set windowWidth to item 1 of windowSize
        set tabItems to every UI element of tabGroup whose role is "AXRadioButton"
        repeat with tabIndex from 1 to (count of tabItems)
          if tabIndex > (count of tabNames) then exit repeat
          set tabItem to item tabIndex of tabItems
          set tabPosition to position of tabItem
          set tabSize to size of tabItem
          set tabCenter to (item 1 of tabPosition) - windowX + ((item 1 of tabSize) / 2)
          set centerRatio to round ((tabCenter * 10000) / windowWidth)
          set output to output & (item tabIndex of tabNames) & (ASCII character 9) & centerRatio & linefeed
        end repeat
      end if
    end if
    return output
  end tell
end tell
APPLESCRIPT
    if awk -F '\t' 'NF == 2 && $2 ~ /^[0-9]+$/ { valid++ } END { exit !valid }' "$snapshot_tmp"; then
      mv "$snapshot_tmp" "$tabs_cache"
    fi
    rm -f "$snapshot_tmp"
    rmdir "$tabs_lock" 2>/dev/null || true
    trap - EXIT
  fi
fi

if [[ -r "$tabs_cache" ]]; then
  while IFS=$'\t' read -r tab_title center_ratio; do
    [[ -n "$tab_title" && "$center_ratio" == <-> ]] || continue
    tab_sessions+=("${tab_title%% | *}")
    tab_center_ratios+=("$center_ratio")
  done < "$tabs_cache"
fi

# Ghostty titles are best-effort: shell/title changes can temporarily replace
# the Zellij session prefix. If none of the visible titles map to agent state,
# render the known sessions instead of producing an entirely blank row.
matched_tabs=0
for tab_session in "${tab_sessions[@]}"; do
  [[ -n "${statuses[$tab_session]-}" ]] && (( matched_tabs += 1 ))
done
(( matched_tabs > 0 )) || tab_sessions=("${sessions[@]}")
tab_count=${#tab_sessions[@]}
(( tab_count > 0 )) || exit 0

# Never query Zellij from this renderer. The push publisher supplies live
# geometry outside zjstatus's render call path.
width="${ZJSTATUS_AGENTS_WIDTH:-${COLUMNS:-110}}"
[[ "$width" == <-> ]] && (( width > 0 )) || width=110

# Leave room for the right-aligned Linear counter at the end of the row.
right_reserved="${ZJSTATUS_LINEAR_WIDTH:-4}"
[[ "$right_reserved" == <-> ]] || right_reserved=4
(( right_reserved < width )) || right_reserved=0

color_base="#1e1e2e"
color_green="#a6e3a1"
color_yellow="#f9e2af"
color_overlay1="#7f849c"
color_red="#f38ba8"

use_native_centers=0
(( ${#tab_center_ratios[@]} == tab_count )) && use_native_centers=1
out=""
cursor=0
label_width=3

for (( i = 1; i <= tab_count; i++ )); do
  session="${tab_sessions[$i]}"
  if (( use_native_centers )); then
    target=$(( (tab_center_ratios[$i] * width + 5000) / 10000 ))
  else
    target=$(( ((2 * i - 1) * width + tab_count) / (2 * tab_count) ))
  fi

  agent_status="${statuses[$session]-}"
  [[ -n "$agent_status" ]] || continue

  case "$agent_status" in
    working|tool) icon="●"; color="$color_green" ;;
    waiting)      icon="◆"; color="$color_yellow" ;;
    idle)         icon="○"; color="$color_overlay1" ;;
    *)            icon="×"; color="$color_red" ;;
  esac

  label="󰚩 ${icon}"
  styled_label="#[fg=${color_overlay1}]󰚩 #[fg=${color}]${icon}"

  label_start=$(( target - (label_width / 2) ))
  (( label_start < cursor )) && label_start=$cursor
  out+="$(printf '%*s' "$(( label_start - cursor ))" '')#[bg=${color_base}]${styled_label}#[bg=${color_base},fg=${color_overlay1}]"
  cursor=$(( label_start + label_width ))
done

content_width=$(( width - right_reserved ))
(( cursor < content_width )) && out+="$(printf '%*s' "$(( content_width - cursor ))" '')"

printf '%s\n' "$out"
