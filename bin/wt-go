#!/usr/bin/env bash
# Pick a worktree across all repositories and switch to it via Worktrunk.

set -euo pipefail
shopt -s nullglob

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
source "$SCRIPT_DIR/../lib/wt/return-directory.sh"

DEV_WORKSPACE="${DEV_WORKSPACE:-${HOME}/dev}"
paths=()
labels=()

open_sessions="$({
  /usr/bin/osascript 2>/dev/null <<'APPLESCRIPT' || true
tell application "Ghostty"
  set output to ""
  repeat with ghosttyWindow in windows
    repeat with ghosttyTab in tabs of ghosttyWindow
      set tabName to name of ghosttyTab
      if tabName contains " | " then
        set AppleScript's text item delimiters to " | "
        set tabName to text item 1 of tabName
        set AppleScript's text item delimiters to ""
      end if
      set output to output & tabName & linefeed
    end repeat
  end repeat
  return output
end tell
APPLESCRIPT
  /Users/rmgpinto/dev/personal/devenv/bin/zellij list-sessions --no-formatting 2>/dev/null \
    | awk '!/\(EXITED - attach to resurrect\)$/ { sub(/ \[Created.*/, ""); if (length) print }' || true
} | sort -u)"

session_is_open() {
  local candidate="$1"
  while IFS= read -r session; do
    [ "$session" = "$candidate" ] && return 0
  done <<<"$open_sessions"
  return 1
}

if [ "$#" -gt 0 ]; then
  target="$1"
  prompt=""
  [ -d "$target" ] || {
    echo "wt-go: no such worktree: $target" >&2
    exit 1
  }
  cd "$target"
  set_worktrunk_return_directory "$PWD"
  if [ -s .wt-claude-prompt ]; then
    prompt=$(<.wt-claude-prompt)
    rm -f .wt-claude-prompt
  fi
  exec zcode "$prompt"
fi

for root in "$DEV_WORKSPACE/personal" "$DEV_WORKSPACE/work"; do
  [ -d "$root" ] || continue
  for repo in "$root"/*; do
    [ -d "$repo/.git" ] || continue
    for path in "$repo"/.worktrees/*/; do
      branch=$(/usr/bin/git -C "$path" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
      [ "$branch" = HEAD ] && branch=""
      branch=${branch//\//-}
      session="$(basename "$repo")${branch:+-$branch}"
      session=${session:0:60}
      session_is_open "$session" && continue

      paths+=("${path%/}")
      relative="${path#"$DEV_WORKSPACE"/}"
      labels+=("${relative/\/.worktrees\// → }")
    done
  done
done

if [ "${#paths[@]}" -eq 0 ]; then
  echo "wt-go: no unopened worktrees found under $DEV_WORKSPACE" >&2
  exit 1
fi

selection=$(printf '%s\n' "${labels[@]}" |
  gum filter --header "Pick a worktree" --placeholder "type to filter")

for i in "${!labels[@]}"; do
  if [ "${labels[$i]}" = "$selection" ]; then
    if [ -s "${paths[$i]}/.wt-claude-prompt" ]; then
      cd "${paths[$i]}"
      set_worktrunk_return_directory "$PWD"
      prompt=$(<.wt-claude-prompt)
      rm -f .wt-claude-prompt
      exec zcode "$prompt"
    fi
    if [ -n "${WORKTRUNK_DIRECTIVE_CD_FILE:-}" ]; then
      printf '%s\n' "${paths[$i]}" >"$WORKTRUNK_DIRECTIVE_CD_FILE"
    else
      printf '%s\n' "${paths[$i]}"
    fi
    exit 0
  fi
done

echo "wt-go: selected worktree disappeared" >&2
exit 1
