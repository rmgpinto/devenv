#!/usr/bin/env zsh
# Push status output to zjstatus without periodic command widgets.

set -euo pipefail

root=/Users/rmgpinto/dev/personal/devenv
force_linear=0
force_geometry=0
for arg in "$@"; do
  case "$arg" in
    --force) force_linear=1; force_geometry=1 ;;
    --geometry) force_geometry=1 ;;
  esac
done
zellij_bin="${ZELLIJ_BIN:-$HOME/.local/share/mise/installs/zellij/latest/zellij}"
jq_bin="${JQ:-$HOME/.local/share/mise/installs/jq/latest/jq}"
lock="${TMPDIR:-/tmp}/zjstatus-publish.lock"
log="${TMPDIR:-/tmp}/zjstatus-publish.last"

if [[ ! -x "$zellij_bin" || ! -x "$jq_bin" ]]; then
  [[ -t 2 ]] && echo "zjstatus-publish: zellij or jq is unavailable" >&2
  exit 0
fi
have_lock=0
for attempt in {1..40}; do
  if mkdir "$lock" 2>/dev/null; then
    have_lock=1
    break
  fi
  lock_at="$(stat -f %m "$lock" 2>/dev/null || printf '0')"
  if (( $(date +%s) - lock_at > 10 )); then
    rmdir "$lock" 2>/dev/null || true
  else
    sleep 0.05
  fi
done
(( have_lock )) || exit 0
trap 'rmdir "$lock" 2>/dev/null || true' EXIT

sessions="$(/usr/bin/env -u ZELLIJ -u ZELLIJ_SESSION_NAME \
  "$zellij_bin" list-sessions --short --no-formatting 2>/dev/null || true)"
[[ -n "$sessions" ]] || exit 0
printf 'sessions=%s\n' "${sessions//$'\n'/,}" > "$log"

if (( force_geometry )); then
  rm -f "${TMPDIR:-/tmp}/zjstatus-ghostty-tabs.tsv"
fi

linear_max_age=5
(( force_linear )) && linear_max_age=0
linear="$(ZJSTATUS_LINEAR_MAX_AGE="$linear_max_age" \
  $root/bin/zjstatus-linear-count | tr -d '\n')"

first_session=1
while IFS= read -r session; do
  [[ -n "$session" ]] || continue
  width="$(/usr/bin/env -u ZELLIJ -u ZELLIJ_SESSION_NAME \
    "$zellij_bin" --session "$session" action list-panes --json 2>/dev/null \
    | "$jq_bin" -r \
      '[.[] | select(.is_plugin | not) | ((.pane_x // 0) + (.pane_columns // 0))] | max // 0' \
      2>/dev/null || true)"
  [[ "$width" == <-> ]] && (( width > 0 )) || width=110

  geometry_age=3
  (( force_geometry && first_session )) && geometry_age=0
  agents="$(ZELLIJ_SESSION_NAME="$session" ZJSTATUS_AGENTS_WIDTH="$width" \
    ZJSTATUS_GHOSTTY_CACHE_AGE="$geometry_age" \
    $root/bin/zjstatus-agents | tr -d '\n')"
  first_session=0

  if /usr/bin/env -u ZELLIJ -u ZELLIJ_SESSION_NAME \
      "$zellij_bin" --session "$session" pipe \
      "zjstatus::pipe::pipe_status::${agents}${linear}" \
      </dev/null 2>>"$log"; then
    printf 'session=%s width=%s pipe=ok\n' "$session" "$width" >> "$log"
  else
    printf 'session=%s width=%s pipe=failed\n' "$session" "$width" >> "$log"
  fi
done <<<"$sessions"
