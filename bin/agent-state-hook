#!/usr/bin/env zsh
set -euo pipefail

agent="${1:-}"
mode="${2:-update}"
state_file="${AGENT_STATE_FILE:-${HOME}/.local/state/agents.json}"

if [[ -z "$agent" ]]; then
  echo "usage: agent-state-hook <agent|prune|delete> [session-name]" >&2
  exit 2
fi

lock="${state_file}.lock"
if [[ -e "$lock" ]] && zmodload zsh/system 2>/dev/null; then
  zsystem flock "$lock" 2>/dev/null || true
fi

if [[ ! -s "$state_file" ]] && ! printf '{}\n' > "$state_file" 2>/dev/null; then
  exit 0
fi

prune_inactive_sessions() {
  command -v zellij >/dev/null 2>&1 || return 0

  active="$(mktemp -t agent-active-sessions.XXXXXX)"
  if ! zellij list-sessions --no-formatting 2>/dev/null \
      | awk '!/\(EXITED - attach to resurrect\)$/ { sub(/ \[Created.*/, ""); if (length) print }' > "$active"; then
    rm -f "$active"
    return 0
  fi

  tmp="$(mktemp -t agent-state.XXXXXX)"
  jq --rawfile active "$active" '
    ($active | split("\n") | map(select(length > 0))) as $active_sessions
    | with_entries(select(.key as $session | $active_sessions | index($session)))
  ' "$state_file" > "$tmp"
  cat "$tmp" > "$state_file"
  rm -f "$tmp"
  rm -f "$active"
}

if [[ "$agent" == "prune" ]]; then
  prune_inactive_sessions
  exit 0
fi

if [[ "$agent" == "delete" ]]; then
  session="${mode:-}"
  [[ -n "$session" ]] || exit 0
  tmp="$(mktemp -t agent-state.XXXXXX)"
  jq --arg session "$session" 'del(.[$session])' "$state_file" > "$tmp"
  cat "$tmp" > "$state_file"
  rm -f "$tmp"
  exit 0
fi

payload="$(mktemp -t agent-hook.XXXXXX)"
cat > "$payload" || true

event="$(jq -r '.hook_event_name // .event // .type // empty' "$payload" 2>/dev/null || true)"
event="${event:-unknown}"
cwd="$(jq -r '.cwd // empty' "$payload" 2>/dev/null || true)"
cwd="${cwd:-$PWD}"
session_id="$(jq -r '.session_id // .sessionId // empty' "$payload" 2>/dev/null || true)"
tool_name="$(jq -r '.tool_name // .toolName // .tool // empty' "$payload" 2>/dev/null || true)"
model="$(jq -r '.model // empty' "$payload" 2>/dev/null || true)"

session="${ZELLIJ_SESSION_NAME:-}"
if [[ -z "$session" ]]; then
  session="$(jq -r '.zellij_session // .zellijSession // empty' "$payload" 2>/dev/null || true)"
fi
if [[ -z "$session" ]]; then
  root="$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null || true)"
  root="${root:-$cwd}"
  repo_root="$root"
  if [[ "$(basename "$(dirname "$repo_root")")" == ".worktrees" ]]; then
    repo_root="$(dirname "$(dirname "$repo_root")")"
  fi
  branch="$(git -C "$cwd" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  [[ "$branch" == "HEAD" ]] && branch=""
  branch="${branch//\//-}"
  session="$(basename "$repo_root")${branch:+-$branch}"
  session="${session[1,60]}"
fi

repo_root="$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null || true)"
repo_root="${repo_root:-$cwd}"
if [[ "$(basename "$(dirname "$repo_root")")" == ".worktrees" ]]; then
  repo_root="$(dirname "$(dirname "$repo_root")")"
fi
branch="$(git -C "$cwd" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
[[ "$branch" == "HEAD" ]] && branch=""

case "$event" in
  SessionStart|Stop|SubagentStop) state_status="idle" ;;
  PermissionRequest) state_status="waiting" ;;
  PreToolUse) state_status="tool" ;;
  UserPromptSubmit|PostToolUse|PreCompact|PostCompact|SubagentStart) state_status="working" ;;
  *) state_status="working" ;;
esac

now="$(date +%s)"
tmp="$(mktemp -t agent-state.XXXXXX)"
jq \
  --arg session "$session" \
  --arg agent "$agent" \
  --arg status "$state_status" \
  --arg event "$event" \
  --arg cwd "$cwd" \
  --arg repo "$repo_root" \
  --arg branch "$branch" \
  --arg session_id "$session_id" \
  --arg tool "$tool_name" \
  --arg model "$model" \
  --argjson updated_at "$now" \
  '
  .[$session] = ((.[$session] // {}) + {
    session: $session,
    cwd: $cwd,
    repo: $repo,
    branch: $branch,
    updated_at: $updated_at,
    agents: ((.[$session].agents // {}) + {
      ($agent): ({
        agent: $agent,
        status: $status,
        event: $event,
        cwd: $cwd,
        repo: $repo,
        branch: $branch,
        session_id: $session_id,
        tool: $tool,
        model: $model,
        pid: env.PID,
        active_at: (
          if $status == "working" or $status == "tool"
          then $updated_at
          else (.[$session].agents[$agent].active_at // 0)
          end
        ),
        updated_at: $updated_at
      } | with_entries(select(.value != "")))
    })
	  })
	  ' "$state_file" > "$tmp"
cat "$tmp" > "$state_file"
rm -f "$tmp"
rm -f "$payload"
