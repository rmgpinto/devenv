# Personal
alias zs='source ~/.zshrc'
alias upgrade_packages='brew update && brew outdated --cask --greedy && brew upgrade && brew upgrade --cask --greedy && brew cleanup && mise plugins update && mise outdated && mise upgrade && mise prune -y'
alias vi='nvim'
alias v='nvim'
function zcode() {
  # Mirror the session-name logic in dotfiles/zellij/.config/zellij/layouts/code.kdl
  # so re-attaching from the same dir hits the layout-renamed session instead of
  # spawning a new one.
  local root cwd branch session
  root=$(/usr/bin/git -C "$PWD" worktree list --porcelain 2>/dev/null | awk '/^worktree / {print $2; exit}')
  root=${root:-$PWD}
  # When the repo lives at <project>/.worktrees/<branch> (independent clone, not a
  # linked worktree), use <project> as the name instead of <branch>.
  [ "$(basename "$(dirname "$root")")" = ".worktrees" ] && root=$(dirname "$(dirname "$root")")
  cwd=$(basename "$root")
  branch=$(/usr/bin/git -C "$PWD" rev-parse --abbrev-ref HEAD 2>/dev/null)
  [ "$branch" = HEAD ] && branch=
  session="${cwd}${branch:+-${branch}}"
  # ZELLIJ_SOCKET_DIR=/tmp/zellij (set in .zshrc) keeps the IPC socket path
  # short. 60 leaves ~12 chars of headroom under the 103-byte sun_path cap.
  (( ${#session} > 60 )) && session="${session:0:60}"
  zellij --layout code attach --create "$session"
}
