# Personal
alias zs='source ~/.zshrc'
alias upgrade_packages='brew update && brew outdated --cask --greedy && brew upgrade && brew upgrade --cask --greedy && brew cleanup && mise plugins update && mise outdated && mise upgrade && mise prune -y'
alias vi='nvim'
alias v='nvim'
alias ls='eza --icons -lah'
alias l='eza --icons -lah'
alias lt='eza --icons --tree --level=2 --long'
alias cat='bat'
alias diff='diff --color=auto'
alias grep='grep --color=auto'
alias g='git'
alias myip='curl -s -4 https://ifconfig.co'
alias flushdns='sudo dscacheutil -flushcache sudo killall -HUP mDNSResponder'
alias setdns='networksetup -setdnsservers Wi-Fi 1.1.1.1 1.0.0.1'
alias unsetdns='networksetup -setdnsservers Wi-Fi 192.168.0.1'
alias tf='terraform'
alias j='just'
alias r='rails'
alias credentials-edit='rails credentials:edit'
alias credentials-edit-dev='rails credentials:edit --environment development'
alias credentials-edit-test='rails credentials:edit --environment test'
alias credentials-edit-prod='rails credentials:edit --environment production'

# Work
alias dkill='docker kill $(docker ps -q) 2>/dev/null; docker rm $(docker ps -aq) 2>/dev/null'
alias halstg='NODE_ENV=staging hal'
alias k='kubectl'
alias ksup='kubectl --context do-ams3-sup-k8s-01'
alias kstg='kubectl --context do-ams3-stg-k8s-01'
alias kprd='kubectl --context do-ams3-prd-k8s-01'

