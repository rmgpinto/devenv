function wt() {
  local cd_file prompt_file
  cd_file=$(mktemp -t wt-cd) || return
  prompt_file=$(mktemp -t wt-prompt) || return
  WT_CD_FILE="$cd_file" WT_PROMPT_FILE="$prompt_file" command wt "$@"
  local rc=$?
  if [ -s "$cd_file" ]; then
    local dir
    dir=$(<"$cd_file")
    if [ -d "$dir" ]; then
      # Drop the prompt before cd so the mise `enter` hook (which spawns
      # zellij from the worktree's .mise.local.toml) sees .wt-claude-prompt
      # when the code layout runs. Copying after cd would race the layout
      # and the claude pane would start without the prompt.
      [ -s "$prompt_file" ] && cp "$prompt_file" "$dir/.wt-claude-prompt"
      cd "$dir"
      # bin/wt strips [hooks] from the worktree's .mise.local.toml (mise hooks
      # have no TTY and can't host zellij). Attach explicitly here.
      if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        zcode
      fi
    fi
  fi
  rm -f "$cd_file" "$prompt_file"
  return $rc
}

function wtl() {
  if [ -t 1 ]; then
    command ls -1d /Users/Shared/dev/work/*/.worktrees/*/ | sed $'s/.*/\e[1;34m&\e[0m/'
  else
    command ls -1d /Users/Shared/dev/work/*/.worktrees/*/
  fi
}

function wtg() {
  local paths display sel idx
  paths=$(wtl)
  display=$(echo "$paths" | sed -e 's|^/Users/Shared/dev/work/||' -e 's|/\.worktrees/|-|' -e 's|/$||')
  sel=$(echo "$display" | gum filter --header "Pick a worktree" --placeholder "type to filter")
  [ -z "$sel" ] && return 1
  idx=$(echo "$display" | grep -nFx -- "$sel" | head -1 | cut -d: -f1)
  [ -z "$idx" ] && return 1
  cd "$(echo "$paths" | sed -n "${idx}p")"
}

# Work
alias gha_watch='test -d .git && last_run_id=""; while true; do latest_run_id=$(~/.local/share/mise/shims/gh run list --user rmgpinto --limit 1 --json databaseId --jq ".[0].databaseId"); if [[ "$latest_run_id" != "$last_run_id" ]]; then last_run_id="$latest_run_id"; ~/.local/share/mise/shims/gh run watch "$latest_run_id"; else sleep 5; fi; done'
alias dkill='docker kill $(docker ps -q) 2>/dev/null; docker rm $(docker ps -aq) 2>/dev/null'
alias halstg='NODE_ENV=staging hal'
