# Personal
alias zs='source ~/.zshrc'
alias upgrade_packages='brew update && brew outdated --cask --greedy && brew upgrade && brew upgrade --cask --greedy && brew cleanup && mise plugins update && mise outdated && mise upgrade && mise prune -y'
alias vi='nvim'
alias v='nvim'
function zcode() {
  local root cwd branch session
  root=$(/usr/bin/git -C "$PWD" worktree list --porcelain 2>/dev/null | awk '/^worktree / {print $2; exit}')
  root=${root:-$PWD}
  [ "$(basename "$(dirname "$root")")" = ".worktrees" ] && root=$(dirname "$(dirname "$root")")
  cwd=$(basename "$root")
  branch=$(/usr/bin/git -C "$PWD" rev-parse --abbrev-ref HEAD 2>/dev/null)
  [ "$branch" = HEAD ] && branch=
  session="${cwd}${branch:+-${branch}}"
  (( ${#session} > 60 )) && session="${session:0:60}"
  # If wt seeded a prompt, force a fresh session so the layout re-runs and the
  # claude pane reads .wt-claude-prompt. Attaching/switching to an existing
  # session would skip the layout, leaving the prompt unread. Never delete the
  # session we're currently sitting in.
  if [ -s "$PWD/.wt-claude-prompt" ] && [ "${ZELLIJ_SESSION_NAME:-}" != "$session" ]; then
    zellij delete-session --force "$session" 2>/dev/null
  fi
  if [ -n "${ZELLIJ:-}" ]; then
    # Already inside a zellij session: switch the current client to the target
    # session instead of attaching, which would stack a nested client and
    # require multiple detaches to escape.
    zellij action switch-session --layout code --cwd "$PWD" "$session"
  else
    zellij --layout code attach --create "$session"
  fi
}
