{
  "extends": "default",
  "meta": {
    "name": "ai",
    "version": "1.0.0",
    "description": "DevEnv AI sandbox profile"
  },
  "workdir": {
    "access": "readwrite"
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.agents",
      "$HOME/.config/claude",
      "$HOME/.config/claude.lock",
      "$HOME/.config/codex",
      "$HOME/.config/mise",
      "$HOME/.config/nono",
      "$HOME/.cache/node",
      "$HOME/.local/share/mise",
      "$HOME/dev",
      "/tmp",
      "/private/tmp"
    ],
    "allow_file": [
      "$HOME/.claude.json"
    ],
    "read_file": [
      "$HOME/dev/CLAUDE.md",
      "$HOME/dev/AGENTS.md",
      "$HOME/.CFUserTextEncoding",
      "$HOME/.config/git/config",
      "$HOME/.config/git/ignore",
      "$HOME/.config/gh/config.yml",
      "$HOME/.gitconfig"
    ],
    "read": [
      "/bin",
      "/etc",
      "/opt",
      "/usr"
    ]
  },
  "network": {
    "block": false,
    "listen_port": [
      1455
    ]
  },
  "environment": {
    "allow_vars": [
      "PATH",
      "HOME",
      "USER",
      "LOGNAME",
      "SHELL",
      "TERM",
      "LANG",
      "LC_*",
      "TMPDIR",
      "MISE_*",
      "XDG_*"
    ],
    "set_vars": {
      "SSL_CERT_FILE": "/etc/ssl/cert.pem",
      "ES_STAGING_URL": "https://elastic.ghostfoundation.org",
      "ES_PRODUCTION_URL": "https://elastic.ghost.org",
      "PROMETHEUS_STAGING_URL": "https://prometheus.ghostfoundation.org",
      "PROMETHEUS_PRODUCTION_URL": "https://prometheus.ghost.org",
      "PERCONA_STAGING_URL": "https://pmm.ghostfoundation.org",
      "PERCONA_PRODUCTION_URL": "https://pmm.ghost.org"
    }
  },
  "env_credentials": {
    "nono-gh-token-read-only": "GH_TOKEN",
    "nono-github-token-read-only": "GITHUB_TOKEN",
    "nono-es-user": "ES_USER",
    "nono-es-staging-password": "ES_STAGING_PASSWORD",
    "nono-es-production-password": "ES_PRODUCTION_PASSWORD",
    "nono-pmm-user": "PMM_USER",
    "nono-pmm-staging-password": "PMM_STAGING_PASSWORD",
    "nono-pmm-production-password": "PMM_PRODUCTION_PASSWORD"
  },
  "unsafe_macos_seatbelt_rules": [
    "(allow user-preference-read)"
  ]
}
