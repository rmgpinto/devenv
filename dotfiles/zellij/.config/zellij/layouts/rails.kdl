layout {
    default_tab_template {
        pane size=2 borderless=true {
            plugin location="file:~/.local/share/mise/installs/zjstatus/latest/bin/zjstatus" {
                format_left "{pipe_status}"
                format_center ""
                format_right ""
                format_space "#[bg=#1e1e2e]"
                format_hide_on_overlength "false"
                pipe_status_format "{output}"
                pipe_status_rendermode "dynamic"
                border_enabled "false"
            }
        }
        pane size=2 borderless=true {
            plugin location="zjstatus"
        }
        children
    }
    tab name="code" split_direction="horizontal" focus=true {
        pane split_direction="vertical" size="70%" {
            pane {
              name "nvim"
              size "40%"
              command "zsh"
              args "-c" "CWD=$(basename \"$PWD\"); BRANCH=$(/usr/bin/git -C \"$PWD\" rev-parse --abbrev-ref HEAD 2>/dev/null); [ \"$BRANCH\" = HEAD ] && BRANCH=; SESSION=\"${CWD}${BRANCH:+-${BRANCH}}\"; SESSION=$(printf '%s' \"$SESSION\" | tr / -); (( ${#SESSION} > 60 )) && SESSION=\"${SESSION:0:60}\"; SOCK=/tmp/nvim-${SESSION}.sock; rm -f \"$SOCK\"; $HOME/.local/share/mise/installs/aqua-neovim-neovim/latest/nvim-macos-arm64/bin/nvim --listen \"$SOCK\""
            }
            pane name="claude" size="60%" {
                command "zsh"
                args "-ic" "agent=cc; pane=claude; [[ \"$PWD\" == \"$HOME/dev/personal/\"* ]] && { agent=cx; pane=codex; }; zellij action rename-pane \"$pane\" 2>/dev/null || true; \"$agent\""
                focus true
            }
        }
        pane split_direction="vertical" name="shell" size="30%" {
            pane {
                name "test"
                command "zsh"
                args "-c" "mise watch -t rails-test -e rb,erb,yml"
            }
            pane {
                name "template"
                command "zsh"
                args "-c" "mise watch -t rails-update-template --watch ../rails-template"
            }
            pane {
                name "server"
                command "zsh"
                args "-c" "mise run rails-dev"
            }
        }
    }
}

