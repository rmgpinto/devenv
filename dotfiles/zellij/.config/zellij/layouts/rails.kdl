layout {
    default_tab_template {
        pane size=2 borderless=true {
            plugin location="zjstatus"
        }
        children
    }
    tab name="code" split_direction="horizontal" focus=true {
        pane split_direction="vertical" size="70%" {
            pane {
              name "nvim"
              size "60%"
              command "zsh"
              args "-c" "CWD=$(basename \"$PWD\"); BRANCH=$(/usr/bin/git -C \"$PWD\" rev-parse --abbrev-ref HEAD 2>/dev/null); [ \"$BRANCH\" = HEAD ] && BRANCH=; SESSION=\"${CWD}${BRANCH:+-${BRANCH}}\"; (( ${#SESSION} > 60 )) && SESSION=\"${SESSION:0:60}\"; zellij action rename-session \"$SESSION\"; SOCK=/tmp/nvim-${SESSION}.sock; rm -f \"$SOCK\"; ~/.local/share/mise/shims/nvim --listen \"$SOCK\""
              focus true
            }
            pane name="claude" size="40%"
        }
        pane split_direction="vertical" name="shell" size="30%" {
            pane {
                name "test"
                command "zsh"
                args "-c" "mise watch -t rails-test -e rb,erb,yml"
            }
            pane {
                name "template"
                command "zsh"
                args "-c" "mise watch -t rails-update-template --watch ../rails-template"
            }
            pane {
                name "server"
                command "zsh"
                args "-c" "mise run rails-dev"
            }
        }
    }
}
