layout {
    default_tab_template {
        pane size=2 borderless=true {
            plugin location="zjstatus"
        }
        children
    }
    tab name="code" split_direction="vertical" focus=true {
        pane {
            name "nvim"
            size "60%"
            command "zsh"
            args "-c" "ROOT=$(/usr/bin/git -C \"$PWD\" worktree list --porcelain 2>/dev/null | awk '/^worktree / {print $2; exit}'); ROOT=${ROOT:-$PWD}; [ \"$(basename \"$(dirname \"$ROOT\")\")\" = \".worktrees\" ] && ROOT=$(dirname \"$(dirname \"$ROOT\")\"); CWD=$(basename \"$ROOT\"); BRANCH=$(/usr/bin/git -C \"$PWD\" rev-parse --abbrev-ref HEAD 2>/dev/null); [ \"$BRANCH\" = HEAD ] && BRANCH=; SESSION=\"${CWD}${BRANCH:+-${BRANCH}}\"; (( ${#SESSION} > 60 )) && SESSION=\"${SESSION:0:60}\"; zellij action rename-session \"$SESSION\"; SOCK=/tmp/nvim-${SESSION}.sock; rm -f \"$SOCK\"; mise activate --shims && ~/.local/share/mise/shims/nvim --listen \"$SOCK\""
            focus true
        }
        pane split_direction="horizontal" size="40%" {
            pane name="claude" size="50%" {
                command "zsh"
                args "-ic" "cc"
            }
            pane name="shell" size="50%"
        }
    }
}

