layout {
    default_tab_template {
        pane size=2 borderless=true {
            plugin location="zjstatus"
        }
        children
    }
    tab name="code" split_direction="vertical" focus=true {
        pane {
            name "nvim"
            size "40%"
            command "zsh"
            args "-c" "SESSION=${ZELLIJ_SESSION_NAME:-}; if [ -z \"$SESSION\" ]; then ROOT=$(/usr/bin/git -C \"$PWD\" worktree list --porcelain 2>/dev/null | awk '/^worktree / {print $2; exit}'); ROOT=${ROOT:-$PWD}; [ \"$(basename \"$(dirname \"$ROOT\")\")\" = \".worktrees\" ] && ROOT=$(dirname \"$(dirname \"$ROOT\")\"); CWD=$(basename \"$ROOT\"); BRANCH=$(/usr/bin/git -C \"$PWD\" rev-parse --abbrev-ref HEAD 2>/dev/null); [ \"$BRANCH\" = HEAD ] && BRANCH=; SESSION=\"${CWD}${BRANCH:+-${BRANCH}}\"; SESSION=$(printf '%s' \"$SESSION\" | tr / -); (( ${#SESSION} > 60 )) && SESSION=\"${SESSION:0:60}\"; fi; SOCK=/tmp/nvim-${SESSION}.sock; rm -f \"$SOCK\"; $HOME/.local/share/mise/installs/aqua-neovim-neovim/latest/nvim-macos-arm64/bin/nvim --listen \"$SOCK\""
        }
        pane split_direction="horizontal" size="60%" {
            pane name="claude" size="65%" {
                command "zsh"
                args "-ic" "agent=cc; pane=claude; [[ \"$PWD\" == \"$HOME/dev/personal/\"* ]] && { agent=cx; pane=codex; }; zellij action rename-pane \"$pane\" 2>/dev/null || true; f=.wt-claude-prompt; if [ -s \"$f\" ]; then p=$(cat \"$f\"); rm -f \"$f\"; \"$agent\" \"$p\"; else \"$agent\"; fi"
                focus true
            }
            pane name="shell" size="35%"
        }
    }
}

