layout {
    default_tab_template {
        pane size=2 borderless=true {
            plugin location="file:~/.local/share/mise/installs/zjstatus/latest/bin/zjstatus" {
                format_left "{command_agents}"
                format_center ""
                format_right "{command_linear}"
                format_space "#[bg=#1e1e2e]"
                format_hide_on_overlength "false"
                command_agents_command "/Users/rmgpinto/dev/personal/devenv/bin/zjstatus-agents"
                command_agents_format "{stdout}"
                command_agents_interval "1"
                command_agents_rendermode "dynamic"
                command_linear_command "/Users/rmgpinto/dev/personal/devenv/bin/zjstatus-linear-count"
                command_linear_format "{stdout}"
                command_linear_interval "5"
                command_linear_rendermode "dynamic"
                border_enabled "false"
            }
        }
        pane size=2 borderless=true {
            plugin location="zjstatus"
        }
        children
    }
    tab name="code" split_direction="vertical" focus=true {
        pane {
            name "nvim"
            size "40%"
            command "zsh"
            args "-c" "SESSION=${ZELLIJ_SESSION_NAME:-}; if [ -z \"$SESSION\" ]; then ROOT=$(/usr/bin/git -C \"$PWD\" worktree list --porcelain 2>/dev/null | awk '/^worktree / {print $2; exit}'); ROOT=${ROOT:-$PWD}; [ \"$(basename \"$(dirname \"$ROOT\")\")\" = \".worktrees\" ] && ROOT=$(dirname \"$(dirname \"$ROOT\")\"); CWD=$(basename \"$ROOT\"); BRANCH=$(/usr/bin/git -C \"$PWD\" rev-parse --abbrev-ref HEAD 2>/dev/null); [ \"$BRANCH\" = HEAD ] && BRANCH=; SESSION=\"${CWD}${BRANCH:+-${BRANCH}}\"; SESSION=$(printf '%s' \"$SESSION\" | tr / -); (( ${#SESSION} > 60 )) && SESSION=\"${SESSION:0:60}\"; fi; SOCK=/tmp/nvim-${SESSION}.sock; rm -f \"$SOCK\"; $HOME/.local/share/mise/installs/aqua-neovim-neovim/latest/nvim-macos-arm64/bin/nvim --listen \"$SOCK\""
        }
        pane split_direction="horizontal" size="60%" {
            pane name="claude" size="65%" {
                command "zsh"
                args "-ic" "p=\"\"; agent=cc; pane=claude; [[ \"$PWD\" == \"$HOME/dev/personal/\"* ]] && { agent=cx; pane=codex; }; zellij action rename-pane \"$pane\" 2>/dev/null || true; f=.wt-claude-prompt; if [ -z \"$p\" ] && [ -s \"$f\" ]; then p=$(cat \"$f\"); rm -f \"$f\"; fi; if [ -n \"$p\" ]; then \"$agent\" \"$p\"; else \"$agent\"; fi"
                focus true
            }
            pane name="shell" size="35%"
        }
    }
}

